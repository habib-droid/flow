
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PALETTE FLOW SECURITY RULES
     * Updated to support Super Admin via Email and Role.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user is an admin.
     * We check for either:
     * 1. A hardcoded Super Admin email (e.g., nooriservices01@gmail.com)
     * 2. The 'admin' role explicitly set in their Firestore profile.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'nooriservices01@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Validates ownership for existing documents during update or delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks ownership based on a field within the document data. */
    function isResourceOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- Collection Rules ---

    /**
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      match /palettes/{paletteId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /collections/{collectionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /likedPalettes/{paletteId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /favoriteColors/{favoriteColorId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /recentPalettes/{recentPaletteId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    match /public_palettes/{paletteId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Allow signed-in users to update (increment likes) or admin to update anything
      allow update: if isSignedIn() && (isResourceOwner(resource.data.userId) || isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])));
      allow delete: if resource != null && (isResourceOwner(resource.data.userId) || isAdmin());
    }
  }
}
